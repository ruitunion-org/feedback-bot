{
  "OTEL_SERVICE_NAME": "RuItUnion.FeedbackBot.App",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimit": {
    "Limit": 1,
    "Interval": "00:00:01"
  },
  "ConnectionStrings": {
    "Telegram": "",
    "RuItUnion-FeedbackBot-Database": ""
  },
  "AppOptions": {
    "FeedbackChatId": 0,
    "Start": "<start_text>"
  },
  "Migrator": {
    "UpdateDatabase": true
  },
  "feature_management": {
    "feature_flags": [
      {
        "id": "ForceCultureSet",
        "enabled": false
      },
      {
        "id": "EnableMigratorFromV01",
        "enabled": false
      }
    ]
  }
}